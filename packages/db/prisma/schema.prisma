generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  SAVED
  APPLIED
  SCREEN
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
  GHOSTED
}

enum Role {
  USER
  ADMIN
}

enum ExperienceLevel {
  INTERN
  JUNIOR
  MID
  SENIOR
  STAFF
  PRINCIPAL
  EXECUTIVE
}

enum SourcePlatform {
  LINKEDIN
  WELLFOUND
  INDEED
  NAUKRI
  CUSTOM
}

enum SalaryPeriod {
  HOURLY
  DAILY
  MONTHLY
  YEARLY
}

enum ScrapeRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  PARTIAL
}

model User {
  id              String           @id @default(cuid())
  clerkId         String           @unique
  email           String           @unique
  name            String?
  firstName       String?
  lastName        String?
  imageUrl        String?
  role            Role             @default(USER)
  skills          String[]         @default([])
  preferredRoles  String[]         @default([])
  experienceLevel ExperienceLevel?
  resumeUrl       String?
  githubUrl       String?
  linkedinUrl     String?
  bio             String?          @db.Text
  location        String?
  onboardedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  applications    Application[]
  resumes         Resume[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Job {
  id             String         @id @default(cuid())
  externalId     String?
  sourcePlatform SourcePlatform @default(CUSTOM)
  source         String
  url            String         @unique
  applyUrl       String
  contentHash    String         @unique

  title       String
  company     String
  location    String?
  remote      Boolean @default(false)
  description String? @db.Text

  roleCategory String?
  skills       String[] @default([])
  tags         String[] @default([])

  salaryMin    Int?
  salaryMax    Int?
  currency     String?
  salaryPeriod SalaryPeriod?

  postedAt   DateTime?
  scrapedAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  isActive   Boolean   @default(true)

  applications Application[]

  @@index([sourcePlatform, postedAt(sort: Desc)])
  @@index([company])
  @@index([roleCategory])
  @@index([isActive, postedAt(sort: Desc)])
  @@index([skills], type: Gin)
  @@map("jobs")
}

model Application {
  id        String             @id @default(cuid())
  userId    String
  jobId     String?
  company   String
  title     String
  location  String?
  status    ApplicationStatus  @default(SAVED)
  appliedAt DateTime?
  notes     String?            @db.Text
  source    String?
  url       String?
  salaryMin Int?
  salaryMax Int?
  currency  String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job?               @relation(fields: [jobId], references: [id], onDelete: SetNull)
  events    ApplicationEvent[]

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("applications")
}

model ApplicationEvent {
  id            String      @id @default(cuid())
  applicationId String
  type          String
  payload       Json?
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, createdAt])
  @@map("application_events")
}

model Resume {
  id           String   @id @default(cuid())
  userId       String
  title        String
  content      String   @db.Text
  fileUrl      String?
  parsedSkills String[] @default([])
  parsedYears  Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("resumes")
}

model ScrapeSource {
  id              String         @id @default(cuid())
  platform        SourcePlatform @unique
  enabled         Boolean        @default(true)
  cron            String?
  rateLimitPerMin Int            @default(20)
  maxConcurrency  Int            @default(2)
  searchQueries   String[]       @default([])
  locations       String[]       @default([])
  lastRunAt       DateTime?
  config          Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  runs ScrapeRun[]

  @@map("scrape_sources")
}

model ScrapeRun {
  id           String          @id @default(cuid())
  sourceId     String?
  platform     SourcePlatform
  query        String?
  location     String?
  status       ScrapeRunStatus @default(PENDING)
  startedAt    DateTime?
  finishedAt   DateTime?
  durationMs   Int?
  pagesScraped Int             @default(0)
  jobsFound    Int             @default(0)
  jobsNew      Int             @default(0)
  jobsUpdated  Int             @default(0)
  jobsFailed   Int             @default(0)
  error        String?         @db.Text
  triggeredBy  String?
  metadata     Json?
  createdAt    DateTime        @default(now())

  source ScrapeSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([platform, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("scrape_runs")
}
