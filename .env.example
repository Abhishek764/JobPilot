# ====================
# Node
# ====================
NODE_ENV=development

# ====================
# Database (Postgres)
# ====================
POSTGRES_USER=jobpilot
POSTGRES_PASSWORD=jobpilot
POSTGRES_DB=jobpilot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://jobpilot:jobpilot@localhost:5432/jobpilot?schema=public

# ====================
# Redis
# ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ====================
# API Server
# ====================
API_PORT=4000
API_HOST=0.0.0.0
API_URL=http://localhost:4000
API_VERSION=v1
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=info

# ====================
# Frontend (Next.js)
# ====================
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ====================
# Clerk Auth
# ====================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ====================
# Gemini AI
# ====================
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash-exp

# ====================
# Scraping (Playwright)
# ====================
SCRAPER_TIMEOUT_MS=30000
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; JobPilotBot/1.0)
SCRAPER_HEADLESS=true

# ====================
# Rate Limiting
# ====================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ====================
# Observability
# ====================
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
